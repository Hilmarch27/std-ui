          "type": "registry:ui",
          "target": "components/ui/input-password.tsx"
        }
      ]
    },
    {
      "name": "input-phone",
      "type": "registry:ui",
      "registryDependencies": ["input"],
      "files": [
        {
          "path": "registry/ui/input/input-phone.tsx",
          "type": "registry:ui",
